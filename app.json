{
  "expo": {
    "name": "Lunar Calendar",
    "slug": "lunar-calendar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "lunarcalendar",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a0533"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bobvu84.lunar.calendar",
      "infoPlist": {
        "NSAppGroupsEntitlements": ["group.com.bobvu84.lunar.calendar.widget"]
      },
      "entitlements": {
        "com.apple.security.application-groups": ["group.com.bobvu84.lunar.calendar.widget"]
      }
    },
    "android": {
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0a0f1e"
      },
      "package": "com.bobvu84.lunar.calendar",
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "./plugins/withLunarWidget"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
